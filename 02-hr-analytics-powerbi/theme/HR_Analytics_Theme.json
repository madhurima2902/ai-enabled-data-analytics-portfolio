{
  "name": "HR Analytics Portfolio Theme",
  "dataColors": [
    "#1E90FF",
    "#1828A8",
    "#EA6A36",
    "#6F007D",
    "#03EF62",
    "#FFB000",
    "#7A5195",
    "#008F7A"
  ],
  "background": "#F7F7FC",
  "foreground": "#05192D",
  "tableAccent": "#03EF62",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#252525"
              }
            },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 12
          }
        ],
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ]
      }
    }
  }
}
